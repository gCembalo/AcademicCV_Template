%--------------------------------- Education --------------------------------//

% Command to buil the Education section.
\newcommand{\Degree}{
    \section{\textbf{Education}}
    \vspace{-0.4mm}
    \resumeSubHeadingListStart

    \resumeSubheading % Essential information
    {\SchoolIII}{\CityIII}
    {\DegreeIII}{\DateIII}
    \vspace{-1mm} % Write here all the additional infotmation.
    \ifdefstring{\AdditionalInformationIII}{Yes}{
        % If you wrote "Yes" in AdditionalInformation
        \resumeItemEducation
        {Assessment: \AssesmentIII}{}
        {\AvgGradeII}{\AccTranscriptIII}
        {\ThesisII}{\ThesisLinkIII}
        {\SupervisorI}
    }{
        % If different from Yes
    }

    \resumeSubheading
    {\SchoolII}{\CityII}
    {\DegreeII}{\DateII}
    \vspace{-1mm}
    \ifdefstring{\AdditionalInformationII}{Yes}{
        % If you wrote "Yes" in AdditionalInformation
        \resumeItemEducation
        {Assessment: \AssesmentII}{}
        {\AvgGradeII}{\AccTranscriptII}
        {\ThesisII}{\ThesisLinkII}
        {\SupervisorII}
    }{
        % If different from Yes
    }

    \resumeSubheading
    {\SchoolI}{\CityI}
    {\DegreeI}{\DateI}
    \vspace{-1mm}
    \ifdefstring{\AdditionalInformationI}{Yes}{
        % If you wrote "Yes" in AdditionalInformation
        \resumeItemEducation
        {Assessment: \AssesmentI}{}
        {\AvgGradeI}{\AccTranscriptI}
        {\ThesisI}{\ThesisLinkI}
        {\SupervisorIII}
    }{
        % If different from Yes
    }

    \resumeSubHeadingListEnd
    \vspace{-6mm}
}



