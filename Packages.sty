% To write in the document all the information, taken from data file.

\usepackage{etoolbox} % To handle the empty bracket
\usepackage{fontawesome5} % For the icon

% To import all the information
\usepackage{Data}

% Header
% with: #1 : Name Surname
%       #2 : Phone number (with for example +39)
%       #3 : email address
%       #4 : Personal page url
%       #5 : Github account name
%       #6 : Address
%       #7 : Linkedin profile
\newcommand{\header}{
    \begin{center}
        {\Huge\textbf{\name}}
    \end{center}
    \vspace{-6mm}

    \begin{center}
        \small{
        \phone 
        \ifblank{\mail}{}{ | \href{mailto:\mail}{\mail}} 
        \ifblank{\website}{}{ | \href{\website}{Personal page}} 
        \ifblank{\githubname}{}{ | \socialicon{\faGithub} \href{https://github.com/\githubname}{\githubname}}
        }
    \end{center}

    % \ifdefempty controlla se la macro \linkedin è definita come {}
    \ifdefempty{\linkedin}{}{%
        \vspace{-4mm}
        \begin{center}
            \small{%
                \socialicon{\faLinkedin} \href{https://www.linkedin.com/in/\linkedin/}{\linkedin}%
            }
        \end{center}
    }

    \vspace{-5mm}
    \begin{center}
        \small{\address}
    \end{center}
    \par\hbox{} % Forza la chiusura corretta del blocco
    \vspace{-4mm}
}



