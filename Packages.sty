% Command to build the header
\newcommand{\header}{
    \begin{center}
        {\Huge\textbf{\name}}
    \end{center}
    \vspace{-4mm}

    \begin{center}
        \small{
        Date and Place of Birth: \Birth \ -\ \BirthCity , \BirthNation
        }
    \end{center}
    \vspace{-6mm}
    
    \begin{center}
        \small{
        \phone 
        \ifblank{\mail}{}{ | \href{mailto:\mail}{\mail}} 
        \ifblank{\website}{}{ | \href{\website}{Personal page}} 
        \ifblank{\githubname}{}{ | \socialicon{\faGithub} 
        \href{https://github.com/\githubname}{\githubname}}
        }
    \end{center}

    % \ifdefempty check if macro \linkedin is defined as {}
    \ifdefempty{\linkedin}{}{%
        \vspace{-4mm}
        \begin{center}
            \small{%
                \socialicon{\faLinkedin} 
                \href{https://www.linkedin.com/in/\linkedin/}{\linkedin}%
            }
        \end{center}
    }
    \vspace{-6mm}

    \begin{center}
        \small{\address}
    \end{center}
    \par\hbox{} % Force the correct end of the block
    \vspace{-4mm}
}



