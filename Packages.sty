% Commands for icon sizing and positioning
\newcommand{\socialicon}[1]{\raisebox{-0.05em}{\resizebox{!}{1em}{#1}}}
\newcommand{\ieeeicon}[1]{\raisebox{-0.3em}{\resizebox{!}{1.3em}{#1}}}

% Defining the item (such as Skills itemize element)
\newcommand{\resumeItem}[2]{
  \item{
    \textbf{#1}{\hspace{0.5mm}#2 \vspace{-0.5mm}}
  }
}

% Command to generate personal item (for example skills and languages sections)
\newcommand{\resumeSubItem}[2]{\resumeItem{#1}{\hspace{2pt}\small{#2}}\vspace{-6pt}}

% Command to re-define personal item label
\renewcommand{\labelitemi}{$\vcenter{\hbox{\tiny$\bullet$}}$}
\renewcommand{\labelitemii}{$\vcenter{\hbox{\tiny$\circ$}}$}

% Define a itemize style. leftmargin=* is needed to not indent 
% the text (as Latex default).
\newcommand{\resumeSubHeadingListStart}{\begin{itemize}
    [leftmargin=*,labelsep=1mm]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}\vspace{2mm}}

\newcommand{\resumeHeadingSkillStart}{\begin{itemize}
    [leftmargin=*,itemsep=1.7mm, rightmargin=2ex]}
\newcommand{\resumeHeadingSkillEnd}{\end{itemize}\vspace{-2mm}}

% Define a itemize style. To use in sub-itemize, 
% e.g. inside \resumeSubHeadingListStart
\newcommand{\resumeItemListStart}{\begin{itemize}
    [leftmargin=0.4cm,labelsep=1mm,itemsep=0.5mm]}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{-2mm}}


% Build a invisible tabular (almost all the page width), where you can add all 
% your information.
% \exptracolsep{} need to put the information on the right.
%
% For Education section for example:
% (#1 University)                   (#2 City)
% (#3 MSc)                          (#4 Date)
\newcommand{\resumeSubheading}[4]{
\vspace{0.5mm}\item
    \begin{tabular*}{0.98\textwidth}[t]{l@{\extracolsep{\fill}}r}
        \textbf{#1} & \textit{\small{#4}} \\
        \textit{\small{#3}} &  \small{#2}\\
    \end{tabular*}
    \vspace{-2.mm}
}

% Another invisible tabular, this time to write additional information to your 
% degree section:
% (#1 Assessment)                   (#2 --)
% (#3 Average grade)                (#4 Transcript)
% (#5 Thesis)                       (#6 Thesis link)
% (#7 Supervisor)
\newcommand{\resumeItemEducation}[7]{%
    % Controlla se almeno uno dei 6 argomenti NON è vuoto
    \ifboolexpr{
        test {\notblank{#1}} or test {\notblank{#2}} or 
        test {\notblank{#3}} or test {\notblank{#4}} or 
        test {\notblank{#5}} or test {\notblank{#6}} or 
        test {\notblank{#7}}
    }{%
        % Se almeno uno è pieno, stampa tutto
        \vspace{1.5mm}
        \resumeItemListStart
            \begin{tabular*}{0.955\textwidth}[t]{p{0.77\textwidth} @{\extracolsep{\fill}} r}
                \ifstrempty{#1}{}{\small{#1}} & \ifstrempty{#2}{}{\small{#2}}%
                \ifboolexpr{test {\notblank{#3}} or test {\notblank{#4}}}{%
                    \\ \small{#3} & \small{#4}%
                }{}%
                \ifboolexpr{test {\notblank{#5}} or test {\notblank{#6}}}{%
                    \\ \small{#5} & \small{#6}%
                }{}%
                \ifboolexpr{test {\notblank{#7}}}{%
                    \\ \small{#7}%
                }{}%
            \end{tabular*}
        \resumeItemListEnd
    }{%
        % If all the space are empty it doesn't print nothing
    }%
}

% Invisible tabular to write the Project (such as Awards section) itemize
\newcommand{\resumeProject}[4]{
\vspace{0.5mm}\item
    \begin{tabular*}{0.98\textwidth}[t]{l@{\extracolsep{\fill}}r}
        \textbf{#1} & \textit{\small{#3}} \\
        \small{\textit{#2}} & \small{#4}
    \end{tabular*}
    \vspace{-2.4mm}
}

